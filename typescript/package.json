{
  "name": "nanostore",
  "version": "0.1.0",
  "description": "Path-based reactive store with resource draft/dirty/save semantics.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./global": "./dist/index.global.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup --entry.index src/__init__.ts --format esm,cjs,iife --global-name nanostore --minify --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
